# Vercel (only needed for the one-off setup script)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Optional: canonical site URL used for SEO metadata (Open Graph, sitemap, robots).
# Falls back to the Vercel preview URL defined in src/lib/config.ts.
NEXT_PUBLIC_SITE_URL=

# Coming soon mode toggle. Set to "true" to show the Coming Soon landing page
# instead of the full site. Unset or set to anything else to restore the real homepage.
# Toggle this in Vercel Production env vars + redeploy for a zero-fight switch.
NEXT_PUBLIC_COMING_SOON=
